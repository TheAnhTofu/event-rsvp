# =============================================================================
# Event RSVP — template. Thực tế: `.env.prod` = prod; `.env.local` = giống prod,
# chỉ đổi host (NEXT_PUBLIC_APP_URL, BACKEND_URL, USER_API_ALLOWED_ORIGIN).
# Đẩy prod lên Secrets Manager: cd web && npm run secrets:push
# Secret: `event-rsvp/prod/config`
# =============================================================================

# --- URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
BACKEND_URL=http://127.0.0.1:4100
# CRM nội bộ (nếu có service riêng)
# CRM_API_BASE_URL=http://127.0.0.1:4000

# API CORS — * = mọi origin
USER_API_ALLOWED_ORIGIN=*

# --- Postgres ---
DATABASE_URL=
# Tuỳ RDS / local: false | require (mặc định auto theo host; RDS thường require)
# DATABASE_SSL=false
# DATABASE_SSL=require

# --- API process ---
PORT=4100
# Behind nginx/ALB trên production: đặt 1 để Express tin X-Forwarded-*
# TRUST_PROXY=1

# --- PaymentAsia / PA-SYS (Alipay & WeChat — hosted checkout) ---
# Merchant Token + Secret Code từ PaymentAsia; POST form tới hosted page (sandbox hoặc production).
# Chi tiết: agent/knowledge/06-paymentasia-pa-sys-integration.md
# PAYMENTASIA_MERCHANT_TOKEN=
# PAYMENTASIA_SECRET_CODE=
# PAYMENTASIA_USE_SANDBOX=true
# Tuỳ chọn — PA gateway REST (query/refund); hosted checkout không bắt buộc
# PAYMENTASIA_API_KEY=
# PAYMENTASIA_SUBJECT=IAIS Conference registration
# PAYMENTASIA_HOSTED_PAGE_URL=
# PAYMENTASIA_HOSTED_PAGE_URL_ALIPAY=
# PAYMENTASIA_HOSTED_PAGE_URL_WECHAT=
# Tuỳ chọn: notify URL công khai (mặc định = NEXT_PUBLIC_APP_URL + /api/paymentasia/notify)
# PAYMENTASIA_NOTIFY_URL=https://your-domain.com/api/paymentasia/notify

# --- Stripe — test vs live (toggle một biến; backend: source-backend/src/lib/stripe-secret.ts) ---
# false = dùng *_TEST; true = dùng *_LIVE (hoặc STRIPE_PRODUCTION_*)
STRIPE_USE_LIVE_MODE=false

# Test (sk_test_ / whsec_ từ Stripe → Test mode)
STRIPE_SECRET_KEY_TEST=
STRIPE_WEBHOOK_SECRET_TEST=

# Live / production (sk_live_… — cùng team với pk_live_ ở frontend)
STRIPE_SECRET_KEY_LIVE=
STRIPE_WEBHOOK_SECRET_LIVE=

# Publishable (test) — khi STRIPE_USE_LIVE_MODE=false hoặc admin tắt live
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Publishable (live) — khi live mode; API /api/stripe/publishable-config chọn key theo mode (env + DB)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_LIVE=
# Tuỳ chọn — alias server-only (không cần NEXT_PUBLIC_)
# STRIPE_PUBLISHABLE_KEY_TEST=
# STRIPE_PUBLISHABLE_KEY_LIVE=

# Tuỳ chọn — alias giống STRIPE_SECRET_KEY_LIVE / STRIPE_WEBHOOK_SECRET_LIVE (Secrets Manager)
# STRIPE_PRODUCTION_SECRET_KEY=
# STRIPE_PRODUCTION_WEBHOOK_SECRET=

# Fallback nếu không set *_TEST / *_LIVE (không khuyến nghị)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Admin JWT (≥32 chars; openssl rand -hex 32) ---
ADMIN_SESSION_SECRET=
# ADMIN_AUTH_DISABLED=true

# --- Rate limit (Express `source-backend`) ---
# Cửa sổ mặc định 15 phút, tối đa 600 request/IP
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=600
# Gửi bulk email từ admin — mặc định 60s / 30 req
# ADMIN_BULK_EMAIL_WINDOW_MS=60000
# ADMIN_BULK_EMAIL_MAX=30

# --- Email: Resend / SES ---
EMAIL_PROVIDER=resend
AWS_REGION=
AWS_DEFAULT_REGION=
AWS_SES_FROM_EMAIL=
# AWS_SES_CONFIGURATION_SET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Ghi đè từ runtime config / App Config (tuỳ deploy)
# EMAIL_PRIMARY_RESEND=true
# APP_CONFIG_EMAIL_PRIMARY_RESEND=true
# APP_CONFIG_STRIPE_LIVE=true

# Giảm giá (early-bird, mã khuyến mãi): cấu hình trong Postgres `discount_codes`
# (cột `apply_without_code` = áp khi user không nhập mã; migration `014_discount_auto_apply.sql`).

# Copy email / thông báo sự kiện
# EMAIL_EVENT_TITLE=IAIS Annual Conference
# SLACK_WEBHOOK_URL=

# Ảnh email (URL tuyệt đối hoặc sync lên S3)
# EMAIL_HEADER_IMAGE_URL=
# EMAIL_ASSET_FORUM_CALENDAR_URL=
# EMAIL_ASSET_FORUM_LOCATION_URL=
# EMAIL_ASSET_FORUM_GLOBE_URL=
# EMAIL_ASSET_QR_PLACEHOLDER_URL=
# EMAIL_ASSET_RECEIPT_SIGNATURE_URL=

# --- S3 (bank slips, email assets) ---
S3_BUCKET=
# BANK_SLIP_BUCKET=
# EMAIL_ASSETS_S3_BUCKET=
# EMAIL_ASSETS_S3_KEY=email-assets/email-header.png
# EMAIL_ASSETS_S3_PREFIX=email-assets

# --- SQS (optional — worker xử lý async) ---
# SQS_NOTIFICATION_QUEUE_URL=
# SQS_EMAIL_QUEUE_URL=
# Bảo vệ POST nội bộ tới worker queue
# INTERNAL_QUEUE_PROCESS_TOKEN=
# Số registration/email mỗi batch khi đẩy queue
# BULK_EMAIL_QUEUE_CHUNK_SIZE=
# Khoảng cách tối thiểu giữa từng email bulk (ms)
# BULK_EMAIL_MIN_INTERVAL_MS=

# --- Webhook thanh toán / tích hợp (optional) ---
# PAYMENT_NOTIFY_WEBHOOK_URL=
# PAYMENT_NOTIFY_WEBHOOK_SECRET=

# --- AWS credentials (local CLI; production thường dùng IAM role) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Figma (script: `web/scripts/export-figma-forum-icons-to-s3.mjs`) ---
# FIGMA_ACCESS_TOKEN=

# --- Hóa đơn PDF (Acknowledge) ---
# INVOICE_ISSUER_NAME=
# INVOICE_ISSUER_ADDRESS=
# INVOICE_BANK_NAME=
# INVOICE_BANK_ACCOUNT_NAME=
# INVOICE_BANK_ACCOUNT_NO=
# INVOICE_BANK_SWIFT=
# INVOICE_PAYMENT_DEADLINE_TEXT=
# INVOICE_NOTO_FONT_PATH=

# --- Phí đăng ký (HKD; dùng chung FE + source-backend) ---
# In-person / online base fees (no audience) are fixed in code (15 / 10 HKD).
# NEXT_PUBLIC_REGISTRATION_FEE_MEMBERS_HKD=8500
# NEXT_PUBLIC_REGISTRATION_FEE_INDUSTRY_HKD=6000
# NEXT_PUBLIC_REGISTRATION_FEE_FELLOW_HKD=0
# NEXT_PUBLIC_REGISTRATION_FEE_VIRTUAL_HKD=0

# --- API đăng ký công khai (dev có default trong code) ---
# USER_API_KEY=

# --- Next.js (public) ---
# NEXT_PUBLIC_LAUNCH_GATE_DISABLED=true
# NEXT_PUBLIC_AUTOFILL_REG=1

# --- Seed DB (npm run db:seed trong web/) ---
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=
# SEED_VIEWER_EMAIL=viewer@example.com
# SEED_VIEWER_PASSWORD=

# --- Scripts deploy / EC2 (tuỳ máy) ---
# EC2_INSTANCE_ID=
# AWS_REGION=ap-southeast-1
