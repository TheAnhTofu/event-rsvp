# Sao chép thành deploy.env trong cùng thư mục (deploy.env đã được gitignore).
# ./scripts/deploy-ecs.sh tự nạp deploy.env nếu tồn tại.

AWS_PROFILE=newtofu
AWS_REGION=ap-southeast-1
ECR_REPOSITORY=event-rsvp-web
ECS_CLUSTER=event-rsvp-cluster-sg
ECS_SERVICE=event-rsvp-service-sg
# IMAGE_TAG=latest
# Fargate x86 (mặc định): không cần đổi. Task ARM/Graviton: DOCKER_PLATFORM=linux/arm64
# DOCKER_PLATFORM=linux/amd64

# --- ECS task env (Amazon SES) — dùng với scripts/ecs-update-task-env-ses.sh ---
# Địa chỉ đã verify trong SES (cùng region ap-southeast-1). Bắt buộc trước khi chạy script.
# AWS_SES_FROM_EMAIL=no-reply@your-verified-domain.com
# URL công khai app (Stripe success / link); khớp origin người dùng mở.
# NEXT_PUBLIC_APP_URL=https://your-alb-or-domain.example.com
