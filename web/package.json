{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "bash scripts/db-migrate-psql.sh",
    "db:migrate:ec2": "node scripts/db-migrate-ec2-ssm.mjs",
    "db:seed": "node --env-file=../.env.local scripts/seed-db.mjs",
    "db:create-admin": "node --env-file=../.env.local scripts/create-admin-user.mjs",
    "db:create-admin:ec2": "node scripts/create-admin-ec2-ssm.mjs",
    "db:set-ec2-env-rds": "node scripts/set-ec2-database-url-from-rds.mjs",
    "deploy:ec2:migrate": "bash scripts/ec2-migrate-and-deploy.sh",
    "stripe:webhook:create-live": "node --env-file=../.env.local scripts/stripe-create-live-webhook.mjs",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/stripe/webhook --events checkout.session.completed",
    "stripe:print-webhook-secret": "stripe listen --print-secret",
    "stripe:pull-env": "node scripts/stripe-env-from-cli.cjs",
    "deploy:ecs": "bash scripts/deploy-ecs.sh",
    "deploy:ec2": "bash scripts/deploy-ec2.sh",
    "secrets:push": "node scripts/push-env-to-secrets-manager.mjs --secret-id event-rsvp/prod/config --region ap-southeast-1 --files ../.env.prod",
    "secrets:push:dry-run": "node scripts/push-env-to-secrets-manager.mjs --dry-run --files ../.env.prod"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1020.0",
    "@aws-sdk/client-sesv2": "^3.1019.0",
    "@aws-sdk/client-sqs": "^3.1017.0",
    "@fontsource/noto-sans-hk": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@pdf-lib/fontkit": "^1.1.1",
    "@stripe/react-stripe-js": "^3.10.0",
    "@stripe/stripe-js": "^4.10.0",
    "@swc/helpers": "^0.5.19",
    "bcryptjs": "^3.0.3",
    "html5-qrcode": "^2.3.8",
    "jose": "^6.2.2",
    "libphonenumber-js": "^1.12.41",
    "next": "16.2.1",
    "next-intl": "^4.8.3",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "react-toastify": "^11.0.5",
    "resend": "^6.10.0",
    "stripe": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^27.4.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.16"
  }
}
